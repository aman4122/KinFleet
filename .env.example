# ==============================================
# VahanTrack Environment Variables
# ==============================================
# Copy this file to .env and fill in your values

# ---- MongoDB Atlas ----
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/vahantrack?retryWrites=true&w=majority

# ---- JWT Authentication ----
JWT_SECRET=your_jwt_secret_key_min_32_chars_long
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_min_32_chars_long

# ---- Server ----
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ---- App Config ----
COMPLIANCE_ALERT_DAYS=7
CRON_TIMEZONE=Asia/Kolkata
